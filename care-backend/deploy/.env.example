# Copy to care-backend/.env on EC2: cp deploy/.env.example .env

# PostgreSQL (AWS RDS — same as Railway)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-rds-host.eu-north-1.rds.amazonaws.com:5432/postgres?sslmode=require
DB_TYPE=postgres

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Sarvam transcription / scoring
SARVAM_API_KEY=your_sarvam_key

# AWS S3 audio storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_BUCKET=verbilab-care-audio-2026

# Optional
FLASK_ENV=production
DEBUG=FALSE
