# Copy to care-backend/.env on EC2: cp deploy/.env.example .env

# PostgreSQL (AWS RDS)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-rds-host.eu-north-1.rds.amazonaws.com:5432/postgres?sslmode=require
DB_TYPE=postgres

# Public API URL (for audio playback links in dashboard)
PUBLIC_API_URL=https://api.care.verbilab.com

# Auth
JWT_SECRET=change-this-to-a-long-random-string
AUTH_PASSWORD_ENABLED=true

# Sarvam transcription / scoring
SARVAM_API_KEY=your_sarvam_key
SARVAM_CHAT_MODEL=sarvam-30b
CARE_CHUNK_SECONDS=25
SARVAM_STT_MAX_SECONDS=28
# Skip slow LLM scoring — rules engine only (faster bulk uploads)
# CARE_RULES_ONLY_SCORING=1
CARE_MAX_PARALLEL_PROCESSING=2
CARE_USE_DIARIZATION=1
CARE_PIPELINE_WATCHDOG=1
CARE_KPI_DISPLAY_MAX=10
CARE_KPI_MASK_NAMES=1

# AWS S3 audio (bucket in eu-north-1 — NOT us-east-1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_AUDIO_REGION=eu-north-1
S3_BUCKET=verbilab-care-audio-2026

# Google Drive bulk folder sync (Google Cloud Console → API key, Drive API enabled)
GOOGLE_API_KEY=

# CORS — comma-separated frontend origins (production)
CARE_CORS_ORIGINS=https://care.verbilab.com,http://localhost:5173

# AWS SES — login OTP
AWS_SES_REGION=us-east-1
SES_FROM_EMAIL=theverbilab@gmail.com
SES_FROM_NAME=Verbilab CARE
SES_REPLY_TO=theverbilab@gmail.com
SES_SMTP_USERNAME=AKIAxxxxxxxx
SES_SMTP_PASSWORD=your_smtp_password_from_csv
AUTH_OTP_ENABLED=true
OTP_EXPIRY_MINUTES=5
AUTH_OTP_DEV_EXPOSE=false

# Production
FLASK_ENV=production
DEBUG=FALSE
PORT=5000
